<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/FirstFragment">

    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.derk.calc.FirstFragment"
        android:label="Ипотека"
        tools:layout="@layout/fragment_first">
        <action
            android:id="@+id/action_FirstFragment_to_SecondFragment"
            app:destination="@id/SecondFragment" />
    </fragment>

    <fragment
        android:id="@+id/CarLoanFragment"
        android:name="com.derk.calc.CarLoanFragment"
        android:label="Автокредит"
        tools:layout="@layout/fragment_first">
        <action
            android:id="@+id/action_CarLoanFragment_to_SecondFragment"
            app:destination="@id/SecondFragment" />
    </fragment>

    <fragment
        android:id="@+id/BudgetFragment"
        android:name="com.derk.calc.BudgetFragment"
        android:label="Бюджет"
        tools:layout="@layout/fragment_budget" />

    <fragment
        android:id="@+id/SecondFragment"
        android:name="com.derk.calc.SecondFragment"
        android:label="График платежей"
        tools:layout="@layout/fragment_second" />
</navigation>